package com.dbms;

import java.io.IOException;
import java.io.InputStream;
import java.sql.Connection;
import java.sql.DriverManager;
import java.sql.SQLException;
import java.util.Properties;
import java.util.Arrays;
import java.util.HashSet;
import java.util.Set;

public final class DBConnection {
    private static String url;
    private static String username;
    private static String password;

    static {
        loadConfig();
    }

    private DBConnection() {
    }

    private static void loadConfig() {
        Properties properties = new Properties();
        try (InputStream inputStream = DBConnection.class.getResourceAsStream("/db.properties")) {
            if (inputStream != null) {
                properties.load(inputStream);
            }
        } catch (IOException ignored) {
        }

        String configuredUrl = System.getProperty("db.url", properties.getProperty("db.url", "jdbc:oracle:thin:@//localhost:1521/XEPDB1"));
        url = cleanJdbcUrl(configuredUrl);
        username = System.getProperty("db.username", properties.getProperty("db.username", "system")).trim();
        password = System.getProperty("db.password", properties.getProperty("db.password", ""));
    }

    private static String cleanJdbcUrl(String rawUrl) {
        if (rawUrl == null) {
            return "jdbc:oracle:thin:@//localhost:1521/XEPDB1";
        }
        String cleaned = rawUrl.trim();
        if (cleaned.startsWith("db.url=")) {
            cleaned = cleaned.substring("db.url=".length()).trim();
        }
        if (cleaned.startsWith("db-url=")) {
            cleaned = cleaned.substring("db-url=".length()).trim();
        }
        return cleaned;
    }

    public static Connection getConnection() throws SQLException {
        try {
            Class.forName("oracle.jdbc.OracleDriver");
        } catch (ClassNotFoundException ex) {
            throw new SQLException("Oracle JDBC driver ojdbc8 was not found on the classpath.", ex);
        }
        return DriverManager.getConnection(url, username, password);
    }

    public static boolean testConnection() throws SQLException {
        try (Connection connection = getConnection()) {
            return connection != null && connection.isValid(3);
        }
    }

    public static String checkRequiredTables() throws SQLException {
        Set<String> required = new HashSet<>(Arrays.asList("USERS", "SKILLS", "USER_SKILLS", "RESUMES", "AI_ROADMAP", "TASKS", "MOCK_TESTS", "TEST_RESULTS", "CHAT_HISTORY", "PROGRESS"));
        try (Connection connection = getConnection(); java.sql.PreparedStatement statement = connection.prepareStatement("SELECT table_name FROM user_tables"); java.sql.ResultSet resultSet = statement.executeQuery()) {
            while (resultSet.next()) {
                required.remove(resultSet.getString("table_name"));
            }
        }
        if (required.isEmpty()) {
            return "All required tables exist.";
        }
        return "Missing tables: " + required;
    }
    public static String getConfigSummary() {
        return "URL: " + url + "\nUsername: " + username + "\nPassword: " + (password == null || password.isEmpty() ? "not set" : "set");
    }

    public static void configure(String jdbcUrl, String user, String pass) {
        url = cleanJdbcUrl(jdbcUrl);
        username = user;
        password = pass;
    }
}
